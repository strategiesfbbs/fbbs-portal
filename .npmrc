# Hard-fail `npm install` when Node is outside the tested engines range
# (package.json "engines": ">=20 <25") instead of merely warning and then
# falling through to a node-gyp build of better-sqlite3 that needs Visual Studio
# build tools. This protects the non-developer install on the Windows box, which
# is the exact failure mode the engines pin was added to prevent.
engine-strict=true
