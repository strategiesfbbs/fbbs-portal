<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config for IIS deployment (requires the iisnode module installed on the server).

  Deployment steps for IT:
    1. Install Node.js LTS and the iisnode module on the server.
    2. Copy this entire folder to the IIS site's physical path
       (e.g. C:\inetpub\wwwroot\fbbs-portal).
    3. Create an IIS Application pointing at that folder.
    4. Give the AppPool identity write access to the `data\` subfolder
       (that's where uploaded packages are stored).
    5. Optional: enable Windows Authentication on the site if you want
       domain-only access — no code changes required.
    6. Optional: to persist uploads OUTSIDE the app folder (recommended for
       upgrades), set the DATA_DIR environment variable on the AppPool to
       a writable path, e.g. D:\FBBSPortalData.
-->
<configuration>
  <system.webServer>

    <!-- Route all requests to server/server.js via iisnode -->
    <handlers>
      <add name="iisnode" path="server/server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Let iisnode handle everything -->
        <rule name="DynamicContent">
          <match url="/*" />
          <action type="Rewrite" url="server/server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Allow larger uploads (default IIS cap is ~30MB).
         Daily package uploads are still capped by MAX_UPLOAD_MB in the app
         (default 50 MB); bank/report imports use BANK_UPLOAD_MAX_MB
         (default 300 MB), so IIS must allow that larger request through. -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="314572800" />
        <hiddenSegments>
          <add segment="data" />
          <add segment="server" />
          <add segment="node_modules" />
          <add segment="iisnode" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <iisnode
      nodeProcessCommandLine="&quot;%ProgramFiles%\nodejs\node.exe&quot;"
      loggingEnabled="true"
      logDirectory="iisnode"
      devErrorsEnabled="false"
      watchedFiles="web.config;*.js"
    />

  </system.webServer>
</configuration>
