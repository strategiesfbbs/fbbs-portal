# Uploaded documents — stored per-install, never committed
data/current/*
data/archive/*
data/cd-history/*
data/bank-reports/*
data/mbs-cmo/*
data/dropbox/*
data/cd-internal/*
data/structured-notes/*
data/market-color/*
data/exec-summary/*
data/market/*
data/audit.log
!data/current/.gitkeep
!data/archive/.gitkeep
!data/cd-history/.gitkeep
!data/bank-reports/.gitkeep
!data/mbs-cmo/.gitkeep
!data/dropbox/.gitkeep
!data/cd-internal/.gitkeep
!data/structured-notes/.gitkeep
!data/market-color/.gitkeep
!data/exec-summary/.gitkeep
!data/market/.gitkeep

# Node / IIS logs
node_modules/
iisnode/
*.log
npm-debug.log*

# OS junk
.DS_Store
Thumbs.db

# Per-agent IDE / harness state (Claude Code worktrees, settings.local.json,
# launch.json, etc., and any duplicate package-lock files macOS creates when
# two processes write to the same path). Both agents leave artifacts here
# that aren't meant to ship.
# Exception: .claude/agents/ (the shared project subagent roster) IS tracked so
# both agents + teammates get the same roster; machine-specific files stay ignored.
.claude/*
!.claude/agents/
.agents/
.codex/
package-lock[ ]*.json
